# ── Environment ───────────────────────────────────────────────────────────────
# "development" or "production"
ENV=development

# ── Flask Session Security ────────────────────────────────────────────────────
# Secret key used for signing session cookies. Replace with a random 32+ char string in production.
SECRET_KEY=

# ── Symmetric Encryption ──────────────────────────────────────────────────────
# Fernet key used to encrypt DB connection URIs at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty, an ephemeral key will be generated on startup (will lose access to saved connections on restart).
ENCRYPTION_KEY=

# ── Application Database ──────────────────────────────────────────────────────
# SQLite (default for dev) or Postgres (production)
# APP_DB_URI=postgresql://user:password@localhost:5432/querymind
APP_DB_URI=sqlite:///nl2db_app.db

# ── Redis Rate Limiting ───────────────────────────────────────────────────────
# Redis connection URL (e.g. Upstash Redis). Required in production for multi-worker rate limiting.
# REDIS_URL=rediss://default:token@name.upstash.io:6379
REDIS_URL=

# ── Hosted LLM Fallback (Server API Key) ──────────────────────────────────────
# Used if the user doesn't provide their own API key in the UI.
HOSTED_LLM_PROVIDER=groq
HOSTED_LLM_API_KEY=
HOSTED_DAILY_TOKEN_BUDGET=50000

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash
# OPENAI_MODEL=gpt-4o-mini

# ── CORS Origins ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_QUERY=20 per hour
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_EXPLORE=5 per hour

# ── Input Length Controls ─────────────────────────────────────────────────────
MAX_QUESTION_LENGTH=2000
MAX_ALIAS_LENGTH=80
