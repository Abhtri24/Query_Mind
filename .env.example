# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string

# ── App DB (where NL2DB stores users/sessions/history) ───────────────────────
# Defaults to SQLite (nl2db_app.db) if not set — fine for local dev
# APP_DB_URI=postgresql://user:pass@localhost/nl2db_app

# ── Hosted LLM fallback (your free key — users fall back to this) ─────────────
HOSTED_LLM_PROVIDER=groq          # groq | gemini
HOSTED_LLM_API_KEY=gsk_your_groq_key_here

# Daily token budget for the hosted key (prevent abuse)
HOSTED_DAILY_TOKEN_BUDGET=50000

# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash
